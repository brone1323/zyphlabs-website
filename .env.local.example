NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Build Fee Price IDs (create in Stripe dashboard as one-time prices)
STRIPE_PRICE_CONTRACTOR_BASIC=price_placeholder
STRIPE_PRICE_CONTRACTOR_STANDARD=price_placeholder
STRIPE_PRICE_CONTRACTOR_PREMIUM=price_placeholder
STRIPE_PRICE_ECOMMERCE_BASIC=price_placeholder
STRIPE_PRICE_ECOMMERCE_STANDARD=price_placeholder
STRIPE_PRICE_ECOMMERCE_PREMIUM=price_placeholder
STRIPE_PRICE_REALESTATE_BASIC=price_placeholder
STRIPE_PRICE_REALESTATE_STANDARD=price_placeholder
STRIPE_PRICE_REALESTATE_PREMIUM=price_placeholder
STRIPE_PRICE_LAWFIRM_BASIC=price_placeholder
STRIPE_PRICE_LAWFIRM_STANDARD=price_placeholder
STRIPE_PRICE_LAWFIRM_PREMIUM=price_placeholder

# Hosting Plan Price IDs (recurring monthly — create in Stripe dashboard)
STRIPE_PRICE_HOSTING_STARTER=price_placeholder
STRIPE_PRICE_HOSTING_PROFESSIONAL=price_placeholder
STRIPE_PRICE_HOSTING_BUSINESS=price_placeholder

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend — sign up at https://resend.com, verify zyphlabs.com domain, then paste your API key
RESEND_API_KEY=re_placeholder

# Analytics — Vercel KV (or any Upstash Redis instance)
# In Vercel: Storage → Create KV → copy the env vars it gives you
# Locally: grab KV_REST_API_URL + KV_REST_API_TOKEN from the Vercel dashboard
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your_token_here

# Protect /admin/analytics — leave blank to allow access without a key (dev mode)
ANALYTICS_SECRET=your_admin_password_here
