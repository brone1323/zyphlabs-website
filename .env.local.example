# PayPal — get these from developer.paypal.com (live credentials)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=live

NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Resend — sign up at https://resend.com, verify zyphlabs.com domain, then paste your API key
RESEND_API_KEY=re_placeholder

# Analytics — Vercel KV (or any Upstash Redis instance)
# In Vercel: Storage → Create KV → copy the env vars it gives you
# Locally: grab KV_REST_API_URL + KV_REST_API_TOKEN from the Vercel dashboard
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your_token_here

# Protect /admin/analytics — leave blank to allow access without a key (dev mode)
ANALYTICS_SECRET=your_admin_password_here
